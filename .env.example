# ── App ──
APP_NAME=Customer Support API
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
WORKER_COUNT=4
CORS_ORIGINS=*

# ── Database ──
# FastAPI runtime — restricted role, NOBYPASSRLS. RLS fully enforced.
DATABASE_URL=postgresql+asyncpg://app_worker:CHANGE_ME@postgres:5432/customer_support
# Alembic migrations — owner role. NEVER used by the application.
ALEMBIC_DATABASE_URL=postgresql+asyncpg://neondb_owner:CHANGE_ME@postgres:5432/customer_support
# Provisioning CLI — app_provisioner role. NEVER used by the application.
PROVISIONER_DATABASE_URL=postgresql+asyncpg://app_provisioner:CHANGE_ME@postgres:5432/customer_support
POSTGRES_PASSWORD=CHANGE_ME


# ── Cache / Queue ──
REDIS_URL=redis://redis:6379/0

# ── Vector Store ──
QDRANT_URL=http://qdrant:6333

# ── Auth ──
JWT_SECRET=generate-a-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── LLM Providers ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
COHERE_API_KEY=...
