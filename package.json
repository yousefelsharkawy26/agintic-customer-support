{
  "name": "customer-support-platform",
  "private": true,
  "scripts": {
    "lint": "pnpm -w -r --if-present run lint",
    "format": "pnpm -w -r --if-present run format:check",
    "typecheck": "pnpm -w -r --if-present run typecheck",
    "lint:dashboard": "pnpm -F dashboard run lint",
    "format:dashboard": "pnpm -F dashboard run format --check && pnpm -F dashboard run format",
    "typecheck:dashboard": "pnpm -F dashboard run typecheck",
    "build:dashboard": "pnpm -F dashboard run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
